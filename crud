<?php
//Update record
$conn = mysqli_connect("localhost","root","","Aman");
if(!$conn)
    die("Connection failed");
// Default empty values
$name = $roll = $sub1 = $sub2 = $sub3 = $total = $percentage = "";
// -------- FETCH DATA (when Update button clicked from table) --------
if(isset($_POST['edit']))
{
    $roll = $_POST['roll'];
    $res = mysqli_query($conn, "SELECT * FROM students WHERE rollno='$roll'");
    if($row = mysqli_fetch_assoc($res))
    {
        $name = $row['name'];
        $sub1 = $row['sub1'];
        $sub2 = $row['sub2'];
        $sub3 = $row['sub3'];
        $total = $row['total'];
        $percentage = $row['per'];
    }
}
// -------- UPDATE RECORD --------
if(isset($_POST['update']))
{
    $roll = $_POST['roll'];
    $name = $_POST['name'];
    $sub1 = $_POST['sub1'];
    $sub2 = $_POST['sub2'];
    $sub3 = $_POST['sub3'];
    $total = $_POST['total'];
    $percentage = $_POST['percentage'];
    $sql = "UPDATE students SET 
            name='$name',
            sub1='$sub1',
            sub2='$sub2',
            sub3='$sub3',
            total='$total',
            per='$percentage'
            WHERE rollno='$roll'";
    if(mysqli_query($conn,$sql))
        echo "<p style='color:green;'>Record updated successfully</p>";
    else
        echo "<p style='color:red;'>Error: ".mysqli_error($conn)."</p>";
}
?>
